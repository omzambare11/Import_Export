<Window x:Class="HelloAutoCADPlugin.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Drawing Analyzer"
        Height="620"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#181818">

    <Window.Resources>

        <!-- BUTTON STYLE -->

        <Style x:Key="ModernButton" TargetType="Button">

            <Setter Property="Background" Value="#3ECF8E"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Width" Value="230"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">

                    <Setter Property="Background" Value="#52E6A7"/>

                </Trigger>

                <Trigger Property="IsPressed" Value="True">

                    <Setter Property="Background" Value="#2DBE7F"/>

                </Trigger>

            </Style.Triggers>

        </Style>

    </Window.Resources>

    <!-- MAIN BORDER -->

    <Border
        Margin="12"
        CornerRadius="16"
        BorderBrush="#3ECF8E"
        BorderThickness="2"
        Background="#1F1F1F">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="110"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>

            </Grid.RowDefinitions>

            <!-- HEADER -->

            <Border
                Grid.Row="0"
                Background="#252526"
                CornerRadius="16,16,0,0">

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>

                    </Grid.ColumnDefinitions>

                    <!-- ICON AREA -->

                    <Border
                        Width="60"
                        Height="60"
                        Background="#3ECF8E"
                        CornerRadius="30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="10">

                        <TextBlock
                            Text="A"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#111111"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    </Border>

                    <!-- TITLE -->

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center">

                        <TextBlock
                            Text="AUTOCAD DRAWING ANALYZER"
                            Foreground="White"
                            FontSize="24"
                            FontWeight="Bold"/>

                        <TextBlock
                            Text="Object Traversing &amp; Drawing Analysis"
                            Foreground="#3ECF8E"
                            FontSize="14"
                            Margin="0,6,0,0"/>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- BUTTON SECTION -->

            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Button
                    x:Name="CountButton"
                    Content="COUNT OBJECTS"
                    Style="{StaticResource ModernButton}"
                    Click="CountButton_Click"/>

            </StackPanel>

            <!-- RESULT SECTION -->

            <Border
                Grid.Row="2"
                Margin="20"
                Background="#252526"
                CornerRadius="12"
                BorderBrush="#2E2E2E"
                BorderThickness="1"
                Padding="15">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>

                    </Grid.RowDefinitions>

                    <!-- RESULT HEADER -->

                    <Border
                        Grid.Row="0"
                        Background="#2D2D30"
                        CornerRadius="8"
                        Padding="10">

                        <TextBlock
                            Text="ANALYSIS RESULT"
                            Foreground="#3ECF8E"
                            FontSize="16"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>

                    </Border>

                    <!-- RESULT CONTENT -->

                    <ScrollViewer
                        Grid.Row="1"
                        Margin="0,15,0,0"
                        VerticalScrollBarVisibility="Auto">

                        <TextBlock
                            x:Name="ResultText"
                            Foreground="#DCDCDC"
                            FontSize="17"
                            FontFamily="Consolas"
                            LineHeight="28"
                            TextWrapping="Wrap"/>

                    </ScrollViewer>

                </Grid>

            </Border>

            <!-- FOOTER -->

            <Border
                Grid.Row="3"
                Background="#252526"
                CornerRadius="0,0,16,16">

                <TextBlock
                    Text="Powered by AutoCAD .NET API"
                    Foreground="#777777"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

            </Border>

        </Grid>

    </Border>

</Window>