<Window x:Class="HelloAutoCADPlugin.ImportExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Export"
        Height="220"
        Width="300"
        WindowStartupLocation="CenterScreen">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center">

        <Button Content="Import DWG"
                Width="180"
                Height="40"
                Margin="0,0,0,15"
                Click="Import_Click"/>

        <Button Content="Export DWG"
                Width="180"
                Height="40"
                Click="Export_Click"/>

    </StackPanel>

</Window>